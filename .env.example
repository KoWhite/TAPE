# ─────────────────────────────────────────────────────────────────────────
# Frontend (Vite) configuration.
#
# Copy this file to `.env` and adjust as needed. `.env` is gitignored.
# These VITE_* values are the ONLY env vars the browser sees — they are
# bundled into the build, so never put secrets here.
#
# All API keys (DeepSeek / FRED / Tavily) belong to the Python bridge and
# live in `server-py/.env` instead. See `server-py/.env.example`.
# ─────────────────────────────────────────────────────────────────────────

# Where the frontend sends /api requests. Leave as `/api` to use the Vite
# dev-server proxy (configured in vite.config.ts → http://127.0.0.1:8787).
# Set a full URL only if you serve the bridge from a different origin.
VITE_API_BASE=/api

# Polling cadence (ms) used when the provider has no push subscription.
VITE_POLL_INTERVAL=3000
