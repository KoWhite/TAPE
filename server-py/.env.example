# Tape bridge configuration. Copy this file to `.env` and fill in your keys.
# `.env` is gitignored — never commit it.

BRIDGE_PORT=8787
OPEND_HOST=127.0.0.1
OPEND_PORT=11111
TAPE_DB_PATH=data/tape.db

# Required for /api/fred/series and /api/macro/buffett-indicator.
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# AI gateway. Keep this server-side; the frontend calls /api/ai/*.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_TIMEOUT_SECONDS=60

# Tavily web search — when set, the AI Daily Brief (and any /api/ai/chat
# call with `enableWebSearch: true`) can fetch fresh news/prices via the
# `search_web` tool. Free tier: 1000 requests/month. Sign up at
# https://tavily.com to get a key (tvly-...).
TAVILY_API_KEY=
TAVILY_TIMEOUT_SECONDS=20
